# DATABASE
POSTGRES_USER=finpulse
POSTGRES_PASSWORD=use_strong_random_password
POSTGRES_DB=finpulse
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT
SECRET_KEY=use_long_random_secret
ALGORITHM=HS256
ACCESS_EXPIRE_MINUTES=15
REFRESH_EXPIRE_DAYS=7

# LLM
LLM_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_MAX_CONCURRENCY=1
OLLAMA_CHAT_TIMEOUT_SEC=180
OLLAMA_NEWS_TIMEOUT_SEC=60
OLLAMA_CHAT_NUM_PREDICT=256
OLLAMA_NEWS_NUM_PREDICT=700
NEWS_USE_LLM=false
NEWS_LLM_FOR_PUBLIC_RSS=true

# GigaChat API
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_TIMEOUT_SEC=60
GIGACHAT_VERIFY_SSL=true
GIGACHAT_NEWS_MAX_TOKENS=700
GIGACHAT_MIN_REQUEST_INTERVAL_SEC=1.2
GIGACHAT_MAX_RETRIES=2
NEWS_PUBLIC_RSS_LLM_LIMIT=12
NEWS_PUBLIC_MAX_AGE_DAYS=7
NEWS_PUBLIC_MIN_FACTS=2
NEWS_PUBLIC_MIN_CONFIDENCE=medium
NEWS_PUBLIC_HIDE_RSS_ONLY_LOW_INFO=true
NEWS_PUBLIC_AUTO_REFRESH_ENABLED=true
NEWS_PUBLIC_AUTO_REFRESH_INTERVAL_HOURS=24
NEWS_PUBLIC_AUTO_REFRESH_STARTUP_DELAY_SEC=30

# App
ADMIN_EMAIL=admin@example.com
FRONTEND_BASE_URL=https://finpulse.example.com
API_BASE_URL=https://finpulse.example.com/api
